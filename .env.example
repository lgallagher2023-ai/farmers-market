# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Found in: Stripe Dashboard → Developers → API Keys
# Use test keys (pk_test_... / sk_test_...) until ready for production
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here

# The secret key is used by Supabase Edge Functions only — never expose it client-side
# Add this in: Supabase Dashboard → Edge Functions → Secrets
# STRIPE_SECRET_KEY=sk_test_your-key-here

# ─── Anthropic ───────────────────────────────────────────────────────────────
# Add this in: Supabase Dashboard → Edge Functions → Secrets (not here)
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── App ─────────────────────────────────────────────────────────────────────
VITE_APP_URL=http://localhost:5173
VITE_PLATFORM_FEE_PERCENT=10
